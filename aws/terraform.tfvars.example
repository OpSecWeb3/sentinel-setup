# ============================================================================
# Sentinel AWS Integration — Example Configuration
#
# Copy this file to terraform.tfvars and fill in your values.
# ============================================================================

# Required: the AWS account ID where Sentinel is hosted.
# Your Sentinel admin can provide this value.
ca_sentinel_account_id = "123456789012"

# Required: name of the IAM role in the Sentinel account.
# Default is "CASentinelServiceRole" — only change if your Sentinel deployment
# uses a different role name.
ca_sentinel_role_name = "CASentinelServiceRole"

# Required: external ID for cross-account trust.
# Copy this value from Sentinel's integration setup screen (Step 1).
# It starts with "sentinel:" and is unique to your integration.
external_id = "sentinel:YOUR_ORG_ID:COPY_FROM_SENTINEL_UI"

# Optional: prefix for resource names (useful for multi-env accounts).
# name_prefix = "ca_sentinel-prod"

# Optional: custom tags merged with Sentinel defaults.
# tags = {
#   Environment = "production"
#   Team        = "security"
#   CostCenter  = "SEC-001"
# }

# --------------------------------------------------------------------------
# Event source — choose ONE of these patterns:
# --------------------------------------------------------------------------

# Pattern A (recommended): EventBridge -> SQS
# enable_eventbridge_rule = true

# Pattern B: existing CloudTrail SNS topic -> SQS
# enable_eventbridge_rule  = false
# cloudtrail_sns_topic_arn = "arn:aws:sns:us-east-1:123456789012:cloudtrail-notifications"

# --------------------------------------------------------------------------
# Global event forwarding (us-east-1)
# --------------------------------------------------------------------------

# Forward IAM, STS, and console sign-in events from us-east-1 to the primary
# region. Enabled by default — disable only if your primary region IS us-east-1
# (in which case it's a no-op anyway) or if you use an org trail.
# enable_global_event_forwarding = true

# --------------------------------------------------------------------------
# Optional event types
# --------------------------------------------------------------------------

# Enable Spot Instance interruption monitoring (for EC2 Spot users).
# enable_spot_interruption_rule = true

# --------------------------------------------------------------------------
# Encryption
# --------------------------------------------------------------------------

# Create a dedicated KMS key (recommended for compliance).
# Set to false to use the AWS-managed aws/sqs key.
# create_kms_key = true

# Or bring your own KMS key:
# create_kms_key = false
# kms_key_arn    = "arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
